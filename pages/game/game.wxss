/* pages/game/game.wxss */
page {
  background-color: #fdf6e3; /* 维持与首页一致的奶油底色 */
}

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 20rpx;
  box-sizing: border-box;
  animation: slideIn 0.5s ease-out; /* 平滑切入动画 */
}

@keyframes slideIn {
  0% { transform: translateY(50rpx); opacity: 0; }
  100% { transform: translateY(0); opacity: 1; }
}

.header {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.title {
  font-size: 50rpx;
  font-weight: 900;
  color: #ff7f50;
  -webkit-text-stroke: 2rpx #8b4513;
  text-shadow: 4rpx 4rpx 0 #8b4513;
  letter-spacing: 2rpx;
}

.turn-indicator {
  margin-top: 15rpx;
  font-size: 32rpx;
  background-color: #fff;
  border: 4rpx solid #8b4513;
  padding: 8rpx 30rpx;
  border-radius: 30rpx;
  box-shadow: 0 6rpx 0 #ccc;
  font-weight: bold;
}

.black-text {
  color: #333;
}

.white-text {
  color: #888;
}

.board-container {
  width: 650rpx;
  height: 650rpx;
  background-color: #ffd8a8; /* 偏卡通明亮的木板色 */
  margin-bottom: 50rpx;
  border: 8rpx solid #8b4513; /* 加粗纯色边框强调卡通感 */
  border-radius: 20rpx; /* 圆角棋盘！更为俏皮 */
  box-shadow: 0 12rpx 0 #d2a679; /* 3D厚度 */
  overflow: hidden; /* 保障canvas不超出圆角 */
}

.board-canvas {
  width: 100%;
  height: 100%;
}

.skills-area {
  display: flex;
  justify-content: space-around;
  width: 100%;
  margin-bottom: 50rpx;
}

.skill-btn {
  width: 180rpx;
  height: 130rpx;
  background-color: #fff;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  border: 4rpx solid #8b4513;
  box-shadow: 0 8rpx 0 #bbb; /* 卡通实体阴影 */
  transition: all 0.1s;
}

/* 技能按下的Q弹反馈 */
.skill-btn:active {
  transform: translateY(8rpx);
  box-shadow: 0 0 0 #bbb;
}

.skill-btn.disabled {
  background-color: #e0e0e0;
  border-color: #aaa;
  box-shadow: 0 8rpx 0 #999;
}
.skill-btn.disabled:active {
  transform: none; /* 禁用的不给按 */
  box-shadow: 0 8rpx 0 #999;
}

.skill-name {
  font-size: 30rpx;
  font-weight: 900;
  color: #ffaa00;
  -webkit-text-stroke: 1.5rpx #8b4513;
  margin-bottom: 8rpx;
}

.skill-status {
  font-size: 24rpx;
  color: #666;
  font-weight: bold;
}

.control-area {
  width: 100%;
}

.restart-btn {
  width: 60% !important;
  margin: 0 auto;
  background-color: #ff4500 !important;
  border: 6rpx solid #8b4513;
  box-shadow: 0 10rpx 0 #8b4513;
  border-radius: 50rpx;
  transition: all 0.1s;
}

.restart-btn:active {
  transform: translateY(10rpx);
  box-shadow: 0 0 0 #8b4513;
}